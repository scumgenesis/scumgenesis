# SFTP (ex.: sftp://host:porta no WinSCP)
# FTP_HOST pode ser "ip" ou "ip:porta". Se usar só ip, defina FTP_PORT.
FTP_HOST=host.exemplo.com:22
FTP_USER=seu_usuario
FTP_PASSWORD=sua_senha
# Caminho até os logs (ex.: pasta na raiz do SFTP)
FTP_DIR=/pasta_do_servidor/SaveFiles/Logs
# Path do Presets/Override (opcional). Se não definido, deriva de FTP_DIR: /{primeiro_segmento}/Config/WindowsServer/Loot/Spawners/Presets/Override
# FTP_PRESETS_OVERRIDE_PATH=/pasta_do_servidor/Config/WindowsServer/Loot/Spawners/Presets/Override

# Server (opcional)
PORT=3000

# CORS - origem permitida para a interface web (opcional, padrão http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

# Timeout da conexão SFTP em ms (opcional, padrão 30000)
FTP_TIMEOUT=30000

# Concorrência SFTP: máx. operações simultâneas (listagem + download). Opcional, padrão 3.
# SFTP_CONCURRENCY=3

# Rate limit para /logs: máx. requisições por IP por janela. Opcional.
# RATE_LIMIT_MAX_REQUESTS=2
# Rate limit para listagens (GET /logs/admin e GET /loot/presets/override): máx. por minuto. Opcional.
# RATE_LIMIT_LIST_MAX_REQUESTS=30
# RATE_LIMIT_WINDOW_SECONDS=60

# Tamanho máximo de arquivo de log para download, em MB. Opcional, padrão 5.
# LOG_MAX_FILE_SIZE_MB=5
